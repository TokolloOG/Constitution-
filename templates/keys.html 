<!DOCTYPE html>
<html>
<head><title>Key Management</title>
<style>
.container{border-radius:10px;box-shadow:0 20px 60px rgba(0,0,0,0.3);padding:40px;max-width:600px;margin:0 auto;}
h1{color:#333;margin-bottom:10px;}
.back-link{color:#667eea;text-decoration:none;font-size:14px;margin-bottom:20px;display:inline-block;}
.back-link:hover{text-decoration:underline;}
.warning{background:#fff3cd;border:1px solid #ffc107;border-radius:5px;padding:15px;margin-bottom:30px;color:#856404;font-size:14px;}
.key-section{margin-bottom:25px;}
.key-section h2{color:#333;font-size:16px;margin-bottom:10px;}
.key-display{background:#f5f5f5;border:1px solid #ddd;border-radius:5px;padding:15px;font-family:'Courier New',monospace;word-break:break-all;font-size:13px;color:#666;max-height:120px;overflow-y:auto;}
.placeholder{color:#999;font-style:italic;}
button{background:#667eea;color:white;border:none;padding:10px 20px;border-radius:5px;cursor:pointer;font-weight:500;transition:background 0.3s;margin-top:10px;}
button:hover{background:#764ba2;}
.info{background:#e7f3ff;border:1px solid #b3d9ff;border-radius:5px;padding:15px;margin-top:30px;color:#004085;font-size:14px;line-height:1.6;}
</style></head>
<body>
<div class="container">
  <a href="/" class="back-link">← Back</a>
  <h1>🔐 Key Management</h1>
  <div class="warning">⚠️ <strong>IMPORTANT:</strong> Never commit real keys to git</div>
  <div class="key-section">
    <h2>Public Key</h2>
    <div class="key-display"><span class="placeholder">PLACEHOLDER_PUBLIC_KEY</span></div>
  </div>
  <div class="key-section">
    <h2>Private Key (Placeholder)</h2>
    <div class="key-display"><span class="placeholder">PLACEHOLDER_PRIVATE_KEY</span></div>
    <p style="font-size:12px">⚠️ This is a placeholder. Do not use in production.</p>
  </div>
  <button onclick="alert('Generate keys with: node gen_keys.js')">Generate New Keys</button>
  <div class="info">
    <strong>How to generate real keys:</strong>
    <ol style="margin-left:20px">
      <li>Run: <code>node gen_keys.js</code></li>
      <li>Copy the keys to <code>.env</code></li>
      <li>Load keys via env: Python uses os.getenv</li>
      <li>Never commit real keys</li>
    </ol>
  </div>
</div>
</body>
</html>