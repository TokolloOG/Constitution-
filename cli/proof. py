import json, datetime, os

PROOF_FILE = "proof/log.jsonl"

def ship(task):
    entry = {
        "date": datetime.date.today().isoformat(),
        "task": task,
        "founder": "TokolloOG"
    }
    os.makedirs("proof", exist_ok=True)
    with open(PROOF_FILE, "a") as f:
        f.write(json.dumps(entry) + "\n")
    print(f"✅ Shipped: {task} | {entry['date']}")

if __name__ == "__main__":
    import sys
    task = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else "Shipped Law 6 CLI"
    ship(task)
