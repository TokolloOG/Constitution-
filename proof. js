  const isHuman = userId && userId.length > 0
  
  if (isHuman) {
    return `\n=== Proof-of-Human v0.1 ===\nStatus: VERIFIED\nUser: ${userId}\nRep: +1 for being real\nWelcome to authenticated internet.\n`
  }
  return "FAILED: Bots not allowed in Heavenet\n"
}

